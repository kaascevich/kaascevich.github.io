---
import MainLayout from "@layouts/MainLayout.astro";
import SearchBar from "@components/Search";
import allPosts from "@utils/allPosts";

/** The title of the Search page. */
const title = "search";

/** The description of the Search page. */
const description = "search for posts";
---

<MainLayout {title} {description} activeNav="search">
  <SearchBar client:load posts={allPosts}/>
</MainLayout>

---
import MainLayout from "@layouts/MainLayout.astro";
import SearchBar from "@components/Search";
import getPosts from "@utils/getPosts";

/** A list of all posts, sorted by date. */
const posts = await getPosts();

const postDetails = posts.map(post => ({ id: post.id, data: post.data }));

/** The title of the Search page. */
const title = "search";

/** The description of the Search page. */
const description = "search for posts";
---

<MainLayout {title} {description} activeNav="search">
  <SearchBar client:load posts={postDetails}/>
</MainLayout>

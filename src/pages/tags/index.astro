---
import MainLayout from "@/layouts/MainLayout.astro"
import Tag from "@/components/Tag.astro"
import tags from "@/utils/uniqueTags"
---

<MainLayout
  title="tags"
  description={`all the tags I've used in my posts (${tags.length} total)`}
  activeNav="tags"
>
  <ul>
    {tags.map(tag => <Tag {tag} size="lg"/>)}
  </ul>
</MainLayout>

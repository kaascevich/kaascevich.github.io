---
import MainLayout from "@/layouts/MainLayout.astro";
import Tag from "@/components/Tag.astro";
import tags from "@/utils/uniqueTags";

/** The title of the Tags section. */
const title = "tags";

/** The description of the Tags section. */
const description = `all the tags I've used in my posts (${tags.length} total)`;
---

<MainLayout {title} {description} activeNav="tags">
  <ul>{tags.map(tag => <Tag {tag} size="lg"/>)}</ul>
</MainLayout>

---
import MainLayout from "@/layouts/MainLayout.astro"
import Tag from "@/components/Tag.astro"
import { allTags } from "@/utils/allTags"
---

<MainLayout
  title="tags"
  description={`all the tags i've used in my posts (${allTags.length} total)`}
  activeNav="tags"
>
  <ul>
    {allTags.map(tag => <Tag {tag} size="lg"/>)}
  </ul>
</MainLayout>

---
import BaseLayout from "@layouts/BaseLayout.astro";
import ExternalLink from "@components/ExternalLink.astro";
import CardList from "@components/CardList.astro";
import Socials from "@components/Socials.astro";

import RSSIcon from "@assets/icons/rss.svg";

import getPosts from "@utils/getPosts";
import { SITE } from "@config";

/** A list of all posts, sorted by date. */
const posts = await getPosts();

/** All featured posts. */
const featuredPosts = posts.filter(post => post.data.featured);

/** All non-featured posts. */
const nonFeaturedPosts = posts.filter(post => !post.data.featured);
---

<BaseLayout activeNav={null}>
  <main>
    <section id="hero">
      <h1 lang="ja">私のサイトへようこそ！</h1>
      <a
        target="_blank"
        href="/rss.xml"
        id="rss-link"
        aria-label="RSS feed"
        title="RSS feed"
      >
        <RSSIcon/>
      </a>

      <article>
        <p>
          I&rsquo;m Kaleb, and I&rsquo;m quite content to float around aimlessly online. Take a gander at <a href="about">my about page</a> for more info.
        </p>
        <p>
          If you want a look under the hood, you can find this site&rsquo;s source code <ExternalLink href="https://github.com/kaascevich/kaascevich.github.io">here</ExternalLink> &mdash; I based it off of <ExternalLink href="https://astro-paper.pages.dev">AstroPaper</ExternalLink> (the code is almost unrecognizable, but the design is pretty similar), and used <ExternalLink href="https://catppuccin.com">Catppuccin</ExternalLink> for the colors.
        </p>
      </article>
      <div class="social-wrapper">
        <div class="social-links-text">&ldquo;Social&rdquo; links:</div>
        <Socials/>
      </div>
    </section>

    <hr aria-hidden={true}/>

    {featuredPosts.length > 0 && <>
      <section id="featured">
        <h2>featured</h2>
        <CardList posts={featuredPosts} useLevel3Heading/>
      </section>
      {nonFeaturedPosts.length > 0 && <hr aria-hidden={true}/>}
    </>}

    {nonFeaturedPosts.length > 0 &&
      <section id="recent-posts">
        <h2>recent</h2>
        <CardList posts={nonFeaturedPosts.slice(0, SITE.postsPerIndex)} useLevel3Heading/>
      </section>
    }

    <div id="all-posts-button-wrapper">
      <a href="/posts/">
        all posts
      </a>
    </div>
  </main>
</BaseLayout>

<style lang="sass">
  #hero
    +padding-y(1rem, 1.5rem)

    h1
      +margin-y(1rem)
      display: inline-block
      +font(font-sizes.$extralarge2, font-weights.$bold)
      @include desktop
        +margin-y(2rem)
        font-size: 3rem
    
    #rss-link
      margin-bottom: 1.5rem
      svg
        margin-bottom: 0.5rem
        +size(1.5rem)
        scale: 110%
        color: colors.$accent
        @include desktop
          margin-bottom: 0.75rem
          scale: 125%
          
    p
      +margin-y(0.5rem)

  .social-wrapper
    margin-top: 1rem
    display: flex
    flex-direction: column
    @include desktop
      flex-direction: row
      align-items: center
  
  .social-links-text
    margin:
      bottom: 0.25rem
      right: 0.5rem
    white-space: nowrap
    @include desktop
      margin-bottom: 0rem

  #featured, #recent-posts
    +padding-y(3rem, 1.5rem)

    h2
      +font(font-sizes.$extralarge2, font-weights.$semibold)
      
  #all-posts-button-wrapper
    margin-bottom: 2rem
    text-align: center
    @include hover-transition(color, colors.$accent)
    @include hide-in-print
    a::after
      content: chars.$arrow-right
</style>

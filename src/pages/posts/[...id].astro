---
import { render } from "astro:content";

import BaseLayout from "@layouts/BaseLayout.astro";
import Tag from "@components/Tag.astro";
import Comments from "@components/Comments";
import Timestamp from "@components/Timestamp";
import PostLinks from "@components/PostLinks.astro";
import ShareLinks from "@components/ShareLinks.astro";
import BackToTop from "@components/BackToTop.astro";
import BackButton from "@components/BackButton.astro";

import ScrollProgress from "@components/scripts/ScrollProgress.astro";
import HeadingLinks from "@components/scripts/HeadingLinks.astro";
import CodeBlockExtras from "@components/scripts/CodeBlockExtras.astro";

import allPosts, { allPostsRaw } from "@utils/allPosts";
import type { Post, PostInfo } from "@content.config";

export interface Props {
  /** The post to display. */
  post: Post,
}

export async function getStaticPaths() {
  return allPostsRaw.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post: rawPost } = Astro.props;
const post: PostInfo = { id: rawPost.id, ...rawPost.data };

const {
  title,
  description,
  published,
  modified,
  tags,
} = post;

const { Content, remarkPluginFrontmatter } = await render(rawPost);
---

<BaseLayout
  {title}
  ogTitle={title}
  {description}
  {published}
  {modified}
  activeNav="posts"
>
  <BackButton/>

  <main>
    <header>
      <h1>{title}</h1>
      <Timestamp {published} {modified}/>
      <span class="reading-time" hidden>Reading time: {remarkPluginFrontmatter.readingTime}</span>
    </header>
    
    <article>
      <Content/>
    </article>

    <ul class="tag-list" hidden>
      {tags.map(tag => <Tag {tag}/>)}
    </ul>
    <hr aria-hidden={true}/>

    <footer>
      <BackToTop/>
      <ShareLinks/>
    </footer>

    <PostLinks {post} posts={allPosts}/>
    <Comments client:only="react"/>
  </main>
</BaseLayout>

<style lang="sass">
  :global(.back-button)
    margin: 2rem auto 0.5rem
    width: 100%
    justify-content: flex-start

  main
    +margin-x(auto)
    width: 100%
    padding-bottom: 3rem

    header
      h1
        +font(font-sizes.$extralarge2, font-weights.$semibold)
        color: colors.$accent
  
      .reading-time
        display: inline
        opacity: 80%
      
      :global(.timestamp)
        +margin-y(0.25rem)

    article
      margin-top: 2rem

    .tag-list
      display: block
      +margin-y(2rem, 1rem)
      @include hide-in-print
      + hr
        +margin-y(2rem)
        @include desktop
          display: none
        @include hide-in-print
    
    footer
      +padding-x(0rem)
      display: flex
      flex-direction: column-reverse
      align-items: center
      justify-content: space-between
      gap: 1.5rem
      
      @include desktop
        flex-direction: row-reverse
        align-items: flex-end
        gap: 1rem

      @include hide-in-print
</style>

<ScrollProgress/>
<HeadingLinks/>
<CodeBlockExtras/>

<script is:inline data-astro-rerun>
  /* go to page start after transition */
  document.addEventListener("astro:after-swap", () =>
    scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>

---
import type { GetStaticPaths } from "astro"

import PaginatedLayout from "@/layouts/PaginatedLayout.astro"

import { SITE } from "@/config"
import { allPosts } from "@/utils/allPosts"

export const getStaticPaths: GetStaticPaths = ({ paginate }) =>
  paginate(allPosts, { pageSize: SITE.postsPerPage })

const { page } = Astro.props
---

<PaginatedLayout
  title="posts"
  description="all the blog posts I've let loose on the world"
  activeNav="posts" 
  {page}
/>

---
import PaginatedLayout from "@/layouts/PaginatedLayout.astro"

import { SITE } from "@/config"
import type { GetStaticPathsOptions } from "astro"
import allPosts from "@/utils/allPosts"

export function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  return paginate(allPosts, { pageSize: SITE.postsPerPage })
}

const { page } = Astro.props
---

<PaginatedLayout
  title="posts"
  description="all the blog posts I've let loose on the world"
  activeNav="posts" 
  {page}
/>

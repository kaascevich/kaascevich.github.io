---
import MainLayout from "@/layouts/MainLayout.astro";
import SongCard from "@/components/SongCard.astro";

import { getCollection } from "astro:content";
import type { EntryInfo } from "@/types";

/** A list of all songs. */
const songs: EntryInfo<"songs">[] = (await getCollection("songs"))
  .map(({ id, data }) => ({ id, ...data }));

/** Original songs. */
const originals = songs.filter(song => !song.remixDetails)
/** Remixed songs. */
const remixes = songs.filter(song => song.remixDetails)
---

<MainLayout
  title="songs"
  description="all the songs I've created or remixed"
  activeNav="songs"
>
  <section id="originals">
    <h2>originals</h2>
    <ul>
      {originals.map(song => <SongCard {song}/>)}
    </ul>
  </section>

  <section id="remixes">
    <h2>remixes</h2>
    <ul>
      {remixes.map(song => <SongCard {song}/>)}
    </ul>
  </section>
</MainLayout>

<style lang="sass">
  section
    padding: 0.75rem 0rem 1.5rem

    h2
      +font(font-sizes.$extralarge2, font-weights.$semibold)
      margin-bottom: 1rem

    ul
      display: flex
      flex:
        direction: row
        wrap: wrap
      gap: 1.5rem
</style>

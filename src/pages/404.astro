---
import Layout from "@layouts/Layout.astro";
import BackButton from "@components/BackButton.astro";
---

<Layout title="404" description="page not found">
  <main>
    <div class="not-found-wrapper">
      <h1>404</h1>
      <span class="url">{Astro.url}</span>
      <p>page not found</p>
      <BackButton class="back-button"/>
    </div>
  </main>
</Layout>

<style lang="sass">
  main
    +margin-x(auto)
    display: flex
    max-width: $max-width
    flex: 1 1 0%
    align-items: center
    justify-content: center
  
  .not-found-wrapper
    margin-bottom: 3.5rem
    display: flex
    flex-direction: column
    align-items: center
    justify-content: center
    h1
      font-size: $font-size-9xl
      font-weight: $font-weight-bold
      color: $color-accent
    p
      margin-top: 1rem
      font-size: $font-size-2xl
      @include desktop
        font-size: $font-size-3xl

  .url
    font-style: italic
    opacity: 80%

  .back-button
    +margin-y(1rem, 0.5rem)
    font-size: $font-size-lg
</style>

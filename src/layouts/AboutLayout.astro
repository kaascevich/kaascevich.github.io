---
import MainLayout from "@layouts/MainLayout.astro";

import ScrollProgress from "@components/scripts/ScrollProgress.astro";
import CodeBlockExtras from "@components/scripts/CodeBlockExtras.astro";

export interface Props {
  /** The about page's frontmatter. */
  frontmatter: {
    /** The about page's title. */
    title: string,
  },
}

const { frontmatter: { title } } = Astro.props;
---

<MainLayout {title} activeNav="about">
  <article>
    <slot/>
  </article>
</MainLayout>

<ScrollProgress/>
<CodeBlockExtras/>

<style lang="sass">
  article
    margin-top: 2rem
</style>

---
import { SITE } from "@/config";
import type { DateTime } from "@/types";
import day from "dayjs";

import "css-preflight";
import "@/styles/base.sass";

import Header, { type NavItem } from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

import { ClientRouter } from "astro:transitions";

import { Schema } from "astro-seo-schema";

interface Props {
  /** This page's title. */
  title?: string | undefined,
  /** The title to use for Open Graph images. */
  ogTitle?: string | undefined,
  /** This page's description. */
  description?: string | undefined,
  /** The date this page was published. */
  published?: DateTime | undefined,
  /** The date this page was last modified. */
  modified?: DateTime | undefined,
  /** The active navigation item. */
  activeNav: NavItem,
}

const {
  title: _title,
  ogTitle = _title ?? SITE.title,
  description = SITE.description,
  published,
  modified,
  activeNav,
} = Astro.props;

const title = _title ? `${_title} | ${SITE.title}` : SITE.title;

/** The canonical URL to this page. */
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width"/>
    <link rel="icon" type="image/png" href="/favicon.ico"/>
    <link rel="icon" type="image/png" href="/favicon.png"/>
    <link rel="canonical" href={canonicalURL}/>
    <meta name="generator" content={Astro.generator}/>

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content="article"/>
    <meta name="description" content={description}/>
    <meta name="author" content={SITE.author}/>
    <link rel="sitemap" href="/sitemap-index.xml"/>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={title}/>
    <meta property="og:title" content={ogTitle}/>
    <meta property="og:description" content={description}/>
    <meta property="og:url" content={canonicalURL}/>
    <meta property="og:site_name" content={SITE.title}/>

    {published && <meta
      property="article:published_time"
      content={day(published).toISOString()}
    />}
    {modified && <meta
      property="article:modified_time"
      content={day(modified).toISOString()}
    />}

    <meta property="twitter:card" content="summary_large_image"/>
    <meta property="twitter:url" content={canonicalURL}/>
    <meta property="twitter:title" content={ogTitle}/>
    <meta property="twitter:description" content={description}/>

    <!-- Google JSON-LD structured data -->
    <Schema item={{
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      datePublished: day(published)?.toISOString(),
      dateModified: day(modified)?.toISOString(),
      author: [{
        "@type": "Person",
        name: SITE.author,
        url: SITE.profile.href,
      }],
    }}>

    <!-- Google Search Console -->
    <meta
      name="google-site-verification"
      content="W67jyEkQq8XW9mdSwbixVBe4OCucIRPrXxpRv2cxhyE"
    />

    <link
      rel="preload"
      href="/fonts/recursive.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/kosugi-maru.ttf"
      as="font"
      type="font/ttf"
      crossorigin="anonymous"
    />

    <meta name="theme-color" content=""/>
    <script is:inline src="/toggleTheme.js"/>

    <ClientRouter/>
  </head>
  <body>
    <Header {activeNav}/>
    <slot/>
    <Footer/>

    <script is:inline data-astro-rerun>
      document.querySelector("main").id = "main-content";

      console.group("Oh well hello! \u{1f44b}");
      console.log("Feeling a bit curious-minded? The whole site's open-source, you know. Take a gander here: https://github.com/kaascevich/kaascevich.github.io");
      console.log("Or you can keep cruising around the Web Inspector (or whatever it's called in your browser of choice). I don't blame you \u{2014} it can be a pretty fun ride!");
      console.log("Anyway, whatever it is you're doing down here, I wish you the best of luck!");
      console.groupEnd();
    </script>
  </body>
</html>

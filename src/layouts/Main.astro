---
import Breadcrumbs from "@components/Breadcrumbs.astro";

export interface Props {
  /** This page's title. */
  title: string,
  /** This page's description. */
  description?: string,
};

const { title, description } = Astro.props;
---

<Breadcrumbs/>
<main>
  <hgroup>
    <h1>{title}</h1>
    {description && <p>{description}</p>}
  </hgroup>
  <slot/>
</main>

<style lang="sass">
  main
    +margin-x(auto)
    width: 100%
    padding:
      left: 1rem
      right: 1rem
      bottom: 1rem
    h1
      font-weight: font-weights.$semibold
      font-size: font-sizes.$extralarge2
      @include desktop
        font-size: font-sizes.$extralarge3
    p
      +margin-y(0.5rem, 1.5rem)
      font-style: italic
</style>

---
import Breadcrumbs from "@components/Breadcrumbs.astro";

export interface Props {
  /** This page's title. */
  title: string,
  /** This page's description. */
  description?: string,
};

const { title, description } = Astro.props;
---

<Breadcrumbs/>
<main>
  <h1>{title}</h1>
  {description && <p>{description}</p>}
  <slot/>
</main>

<style lang="sass">
  main
    +margin-x(auto)
    width: 100%
    max-width: $max-width
    padding:
      left: 1rem
      right: 1rem
      bottom: 1rem
    h1
      font-weight: $font-weight-semibold
      font-size: $font-size-2xl
      @include desktop
        font-size: $font-size-3xl
    p
      +margin-y(0.5rem, 1.5rem)
      font-style: italic
</style>

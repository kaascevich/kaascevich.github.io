---
import Socials from "@components/Socials.astro";
import { SITE } from "@config";

/** The current year. */
const currentYear = new Date().getFullYear();
---

<hr aria-hidden={true}/>
<footer>
  <Socials/>
  <div class="copyright">
    Copyright &copy; {currentYear} {SITE.author}
  </div>
</footer>

<style lang="sass">
  footer
    width: 100%
    margin-top: auto
    @include hide-in-print

    display: flex
    flex-direction: column
    align-items: center
    justify-content: space-between
    +padding-y(1.5rem)

    @include desktop
      flex-direction: row-reverse
      +padding-y(1rem)
  
    .copyright
      +margin-y(0.5rem)
      white-space: nowrap
</style>

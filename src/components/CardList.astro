---
import Card from "@/components/Card";
import type { EntryInfo } from "@/types";

export interface Props {
  /** A list of posts to show cards for. */
  posts: EntryInfo<"posts">[],
  /** Whether to use level 3 headings for the card titles instead of level 2 headings. */
  useLevel3Heading?: boolean,
}

const { posts, useLevel3Heading } = Astro.props;
---

<ul>
  {posts.map(post => <Card {post} {useLevel3Heading}/>)}
</ul>

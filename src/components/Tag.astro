---
import type { Tag } from 'types';

export interface Props {
  /** The tag's name. */
  tag: Tag,
  /** The tag's size. */
  size?: "sm" | "lg",
}

const { tag, size = "sm" } = Astro.props;
---

<li class={size}>
  <a href={`/tags/${tag}/`}>
    <span>{tag}</span>
  </a>
</li>

<style lang="sass">
  li
    display: inline-block
    text-underline-offset: 4px

    a
      position: relative
      text-decoration: underline solid
      padding-right: 0.5rem

      &:hover
        color: $color-accent

      span::before
        content: "#\202f\202f" // two thin spaces
        color: with-opacity(currentcolor, 80%)

  li.lg
    margin: 0.75rem 0.25rem
    a
      font-size: $font-size-lg

  li.sm
    +margin-y(0.25rem)
    a
      font-size: $font-size-sm
</style>

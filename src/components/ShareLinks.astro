---
import SocialLink from "@components/SocialLink.astro";
import { SHARE_LINKS } from "@config";

let shareLinks = SHARE_LINKS.map(social => {
  social.href += Astro.url.href;
  return social;
});
---

<div class="social-icons">
  <span class="share-text">share this post on:</span>
  <div class="share-links-wrapper">
    {shareLinks.map(social => <SocialLink {social}/>)}
  </div>
</div>

<style lang="sass">
  .share-text
    font-style: italic
  
  .share-links-wrapper
    text-align: center

  .social-icons
    display: flex
    flex:
      direction: column
      wrap: wrap
    align-items: center
    justify-content: center
    gap: 0.25rem
    
    +desktop
      align-items: flex-start
</style>

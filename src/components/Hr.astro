---
export interface Props {
  /** Whether to omit padding. */
  noPadding?: boolean,
}

const { noPadding = false } = Astro.props;
---

<div class="hr-wrapper">
  <hr aria-hidden/>
</div>

<style lang="scss" define:vars={{ paddingAmount: noPadding ? "0rem" : "1rem" }}>
  .hr-wrapper {
    max-width: $max-width;
    margin: { left: auto; right: auto; }
    padding: { left: var(--paddingAmount); right: var(--paddingAmount); }
    hr {
      border-color: $color-border;
    }
  }
</style>

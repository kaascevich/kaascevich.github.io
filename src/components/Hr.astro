---
export interface Props {
  /** Whether to omit padding. */
  noPadding?: boolean,
}

const { noPadding = false } = Astro.props;
---

<div class="hr-wrapper">
  <hr aria-hidden/>
</div>

<style define:vars={{ paddingAmount: noPadding ? "0rem" : "1rem" }}>
  .hr-wrapper {
    max-width: theme("maxWidth.3xl");
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--paddingAmount);
    padding-right: var(--paddingAmount);
    hr {
      border-color: rgb(var(--color-border));
    }
  }
</style>

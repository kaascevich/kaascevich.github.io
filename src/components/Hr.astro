---
export interface Props {
  /** Whether to omit padding. */
  noPadding?: boolean,
}

const { noPadding = false } = Astro.props;
---

<div class={`max-w-3xl mx-auto ${noPadding ? "px-0" : "px-4"}`}>
  <hr aria-hidden/>
</div>

<style>
  hr {
    border-color: rgba(var(--color-border));
  }
</style>

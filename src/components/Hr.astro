---
export interface Props {
  /** Whether to omit padding. */
  noPadding?: boolean,
}

const { noPadding = false } = Astro.props;
---

<div class="hr-wrapper">
  <hr aria-hidden/>
</div>

<style lang="sass" define:vars={{ paddingAmount: noPadding ? "0rem" : "1rem" }}>
  .hr-wrapper
    +margin-x(auto)
    +padding-x(var(--paddingAmount))
    hr
      border-color: colors.$border
</style>

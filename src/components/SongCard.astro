---
import { SITE } from "@config";
import type { SongInfo } from "@content.config";

export interface Props {
  /** The song's metadata. */
  song: SongInfo,
}

const { song: { id, title, remixDetails } } = Astro.props;

const sourceURL = `/assets/songs/${id}.mp3`;

/** This song's author. */
const author = remixDetails?.composer ?? SITE.author
---

<li>
  <h2>
    <a href={sourceURL}>{title}</a>
  </h2>

  <p>
    {author} {remixDetails && <>(<a href={remixDetails.linkToOriginal}>orig.</a>)</>}
  </p>

  <audio src={sourceURL} preload="metadata" controls/>
</li>

<style lang="sass">
  li
    background-color: colors.$card
    border-radius: border-radiuses.$large
    padding: 0.75rem
  
    h2
      display: inline-block
      +font(font-sizes.$large, font-weights.$medium)
      color: colors.$accent

    a:hover
      text-decoration: underline

    p
      opacity: 75%
      a
        font-style: italic
    
    audio
      padding-top: 0.25rem
</style>

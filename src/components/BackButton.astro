---
export interface Props {
  /** Classes to apply to the button. */
  class?: string,
}

const { class: className = "" } = Astro.props;

console.log(className);
---

<div class:list={["back-button", className]}>
  <button onclick="history.length === 1 ? location = '/' : history.back()">
    &larr; go back
  </button>
</div>

<style>
  button {
    @apply focus-outline flex hover:opacity-75;
    transition: opacity 0.1s linear;
  }
</style>

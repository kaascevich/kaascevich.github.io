---
export interface Props {
  /** Classes to apply to the button. */
  class?: string,
}

const { class: className = "" } = Astro.props;
---

<div class={className}>
  <button onclick="history.length === 1 ? location = '/' : history.back()">
    go back
  </button>
</div>

<style lang="sass">
  button
    @include hover-transition(opacity, 75%)
    @include hide-in-print
    &::before
      content: "#{chars.$arrow-left}"
</style>

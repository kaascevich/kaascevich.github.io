---
import LinkButton from "@components/LinkButton.astro";
import type { Social } from "types";

export interface Props {
  /** The social media service to display a link to. */
  social: Social,
}

const { social } = Astro.props;
const { default: Icon } = await import(`../assets/icons/socials/${social.name}.svg`);
---

<LinkButton
  href={social.href}
  class="link-button"
  title={social.linkTitle}
  aria-label={social.linkTitle}
>
  <Icon/>
</LinkButton>

<style lang="scss">
  .link-button {
    padding: theme("spacing[1.5]");
    
    transition: all 0.1s ease-in-out;
    &:hover { rotate: 6deg; }
    
    @media (min-width: theme("screens.sm")) {
      padding: theme("spacing.1");
    }
    
    svg {
      transform: scale(125%);
      fill: transparent;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      @media (min-width: 640px) { transform: scale(110%); }
    }
  }
</style>

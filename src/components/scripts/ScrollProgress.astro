<script is:inline data-astro-rerun>
  /** Creates a progress bar showing the current scroll position. */
  function createProgressBar() {
    const progressBarWrapper = document.createElement("div");
    progressBarWrapper.className = "progress-bar-wrapper";

    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar";

    progressBarWrapper.appendChild(progressBar);
    document.body.appendChild(progressBarWrapper);

    document.onscroll = () => {
      const rootNode = document.documentElement;
      const scrollHeight = rootNode.scrollHeight - rootNode.clientHeight;
      const scrolled = rootNode.scrollTop / scrollHeight;

      progressBar.style.width = `${scrolled * 100}%`;
    };
  }
  createProgressBar();
</script>

<style lang="sass" is:global>
  .progress-bar-wrapper
    position: fixed
    top: 0rem
    left: 0rem
    z-index: 10
    +size(100%, 0.25rem)
    @include hide-in-print

    .progress-bar
      +size(0%, 0.25rem)
      background: colors.$accent
</style>
